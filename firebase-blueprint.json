{
  "entities": {
    "AgentProfile": {
      "title": "AgentProfile",
      "description": "Configuration for an AI agent.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "voice": { "type": "string" },
        "knowledgeBase": { "type": "string" },
        "chatKnowledgeBase": { "type": "string" },
        "initialGreeting": { "type": "string" },
        "initialGreetingText": { "type": "string" },
        "theme": { "type": "string" },
        "accentColor": { "type": "string" },
        "calloutMessage": { "type": "string" },
        "logoUrl": { "type": "string" },
        "avatar1Url": { "type": "string" },
        "avatar2Url": { "type": "string" },
        "emailConfig": {
          "type": "object",
          "properties": {
            "formspreeEndpoint": { "type": "string" }
          }
        },
        "fileUploadConfig": {
          "type": "object",
          "properties": {
            "cloudinaryCloudName": { "type": "string" },
            "cloudinaryUploadPreset": { "type": "string" }
          }
        },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "name", "ownerId"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A medical appointment booked through the AI agent.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "description": "YYYY-MM-DD" },
        "time": { "type": "string", "description": "HH:mm" },
        "patientName": { "type": "string" },
        "agentId": { "type": "string" },
        "status": { "type": "string", "enum": ["booked", "cancelled", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "date", "time", "agentId", "status"]
    }
  },
  "firestore": {
    "/agents/{agentId}": {
      "schema": { "$ref": "#/entities/AgentProfile" },
      "description": "Agent profiles."
    },
    "/appointments/{appointmentId}": {
      "schema": { "$ref": "#/entities/Appointment" },
      "description": "Stores all medical appointments."
    }
  }
}
