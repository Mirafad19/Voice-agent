// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: agents
// Document ID: agentId
// Fields:
//   - id: string (required)
//   - name: string (required)
//   - ownerId: string (required, immutable) - owner of the agent profile
//   - [configuration fields...]
//
// Collection: bookings
// Document ID: bookingId
// Fields:
//   - id: string (required)
//   - userName: string (required)
//   - userPhone: string (required, 11 digits)
//   - bookingDate: string (required, YYYY-MM-DD)
//   - status: string (required, ['Pending', 'Confirmed', 'Rejected'])
//   - agentId: string (required)
//
// ===============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "fadahunsi.miracle@gmail.com");
    }

    function isValidAgent(data) {
      return data.id is string && data.name is string && data.ownerId is string;
    }

    function isValidBooking(data) {
      return data.userName is string && data.userName.size() > 0 &&
             data.userPhone is string && data.userPhone.matches("^\\d{11}$") &&
             data.bookingDate is string && data.bookingDate.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.status in ['Pending', 'Confirmed', 'Rejected'];
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /agents/{agentId} {
      allow read: if true; // Public profiles
      allow create: if isAuthenticated() && isValidAgent(request.resource.data) && (isOwner(request.resource.data.ownerId) || isAdmin());
      allow update: if isAuthenticated() && isValidAgent(request.resource.data) && 
                      ((isOwner(resource.data.ownerId) && request.resource.data.ownerId == resource.data.ownerId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated(); // For Director dashboard and status checks
      allow create: if isValidBooking(request.resource.data);
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) && isAdmin());
      allow delete: if isAdmin();
    }
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
